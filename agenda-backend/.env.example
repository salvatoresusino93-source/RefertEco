# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=xxxx
SUPABASE_SERVICE_KEY=xxxx

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-questa-stringa-con-qualcosa-di-lungo-e-casuale

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Orthanc ────────────────────────────────────────────────────────────────
ORTHANC_URL=http://localhost:8042
ORTHANC_WORKLIST_FOLDER=/path/to/orthanc/worklists
ORTHANC_AE_TITLE=ORTHANC

# ─── Ecografo Samsung Medison V5 ─────────────────────────────────────────────
ECOGRAFO_AE_TITLE=SAMSUNGV5
ECOGRAFO_MODALITY=US

# ─── Medico ─────────────────────────────────────────────────────────────────
MEDICO_NOME=Cognome^Nome
