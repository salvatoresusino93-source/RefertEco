# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=xxxx
SUPABASE_SERVICE_KEY=xxxx

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-questa-stringa-con-qualcosa-di-lungo-e-casuale

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Orthanc ────────────────────────────────────────────────────────────────
ORTHANC_URL=http://localhost:8042
ORTHANC_WORKLIST_FOLDER=/path/to/orthanc/worklists
ORTHANC_AE_TITLE=ORTHANC

# ─── Ecografo Samsung Medison V5 ─────────────────────────────────────────────
ECOGRAFO_AE_TITLE=SAMSUNGV5
ECOGRAFO_MODALITY=US

# ─── Medico ─────────────────────────────────────────────────────────────────
MEDICO_NOME=Cognome^Nome

# ─── Pagamento online visita (Stripe) ────────────────────────────────────────
# Lascia vuoto STRIPE_SECRET_KEY per disattivare il pagamento online
# (la prenotazione funziona solo in modalità "paga in studio").
# Chiavi in Dashboard Stripe → Sviluppatori → Chiavi API (usa le chiavi "test" all'inizio).
STRIPE_SECRET_KEY=sk_test_xxxx
# Segreto di firma del webhook (Dashboard Stripe → Sviluppatori → Webhook → endpoint)
STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Importo INTERO della visita in centesimi (8000 = 80,00 €)
IMPORTO_PAGAMENTO_CENT=8000
# URL pubblico dell'app (per i redirect di Checkout). Se non impostata usa APP_URL.
PUBLIC_BASE_URL=https://referteco-production.up.railway.app
